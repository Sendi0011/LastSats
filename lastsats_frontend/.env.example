# LastSats Frontend Environment Variables

# Stacks Network Configuration
# Set to "testnet" for testnet, or omit/set to "mainnet" for mainnet
NEXT_PUBLIC_STACKS_NETWORK=testnet

# LastSats Contract Address
# Format: SP1234...ABCD.contract-name
# Leave empty or comment out to use mock mode for development/testing
# NEXT_PUBLIC_LASTSATS_CONTRACT_ADDRESS=SP1A1JTM2AXXXXXXXXXXXXXXXXXXXXXXXXXXX.lastsats-vault

# Example for testnet:
# NEXT_PUBLIC_LASTSATS_CONTRACT_ADDRESS=ST1234567890ABCDEFGHIJKLMNOPQRSTUV.lastsats-vault

# Example for mainnet:
# NEXT_PUBLIC_LASTSATS_CONTRACT_ADDRESS=SP1234567890ABCDEFGHIJKLMNOPQRSTUV.lastsats-vault